generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
}

enum Round {
  ROUND_OF_16
  QUARTER_FINALS
  SEMI_FINALS
  THIRD_PLACE
  FINAL
}

enum QuizDifficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  active    Boolean  @default(true)
  upiId     String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailVerified              DateTime?
  verificationToken          String?
  verificationTokenExpires   DateTime?
  resetToken                 String?
  resetTokenExpires          DateTime?

  predictions       Prediction[]
  pushSubscriptions PushSubscription[]
  coinBalance       CoinBalance?
  dailyRewards      DailyReward[]
  coinTransactions  CoinTransaction[]
  quizAttempts      QuizAttempt[]
}

model PushSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Team {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  externalId Int?     @unique
  name       String
  shortName  String
  fifaCode   String
  flag       String?
  createdAt  DateTime @default(now())

  players           Player[]
  homeMatches       Match[]      @relation("HomeTeam")
  awayMatches       Match[]      @relation("AwayTeam")
  wonMatches        Match[]      @relation("MatchWinnerTeam")
  winnerPredictions Prediction[] @relation("PredictionWinnerTeam")
}

model Player {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  teamId   String  @db.ObjectId
  name     String
  position String?
  photoUrl String?
  jerseyNumber Int?

  team              Team               @relation(fields: [teamId], references: [id])
  matchScorers      MatchScorer[]
  predictionScorers PredictionScorer[]
}

model Match {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  externalId   Int?        @unique
  round        Round
  homeTeamId   String      @db.ObjectId
  awayTeamId   String      @db.ObjectId
  kickoffTime  DateTime
  status       MatchStatus @default(UPCOMING)
  winnerTeamId String?     @db.ObjectId
  wonOnPenalties Boolean   @default(false)
  locked       Boolean     @default(false)
  createdAt    DateTime    @default(now())

  homeTeam    Team          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winnerTeam  Team?         @relation("MatchWinnerTeam", fields: [winnerTeamId], references: [id])
  scorers     MatchScorer[]
  predictions Prediction[]
}

model MatchScorer {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  matchId  String @db.ObjectId
  playerId String @db.ObjectId

  match  Match  @relation(fields: [matchId], references: [id])
  player Player @relation(fields: [playerId], references: [id])
}

model Prediction {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  userId              String   @db.ObjectId
  matchId             String   @db.ObjectId
  winnerTeamId        String   @db.ObjectId
  usedPointsBooster   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user       User               @relation(fields: [userId], references: [id])
  match      Match              @relation(fields: [matchId], references: [id])
  winnerTeam Team               @relation("PredictionWinnerTeam", fields: [winnerTeamId], references: [id])
  scorers    PredictionScorer[]

  @@unique([userId, matchId])
}

model PredictionScorer {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  predictionId String @db.ObjectId
  playerId     String @db.ObjectId

  prediction Prediction @relation(fields: [predictionId], references: [id])
  player     Player     @relation(fields: [playerId], references: [id])
}

model CoinBalance {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model DailyReward {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  day       Int
  coins     Int
  claimedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, day])
}

model RewardConfig {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  boosterCost            Int      @default(100)
  thirdScorerCost        Int      @default(50)
  fourthScorerCost       Int      @default(150)
  updatedAt              DateTime @updatedAt
}

model CoinTransaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  type        String   // "spend" or "award"
  reason      String   // "booster", "3rd_scorer", "4th_scorer", "daily_reward", etc.
  amount      Int      // positive for both spend and award
  balanceBefore Int
  balanceAfter Int
  relatedId   String?  // predictionId for booster/scorer, null for rewards
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model QuizQuestion {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  question      String
  options       String[]
  correctIndex  Int
  difficulty    QuizDifficulty
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model DailyQuiz {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  date         String   @unique
  questionIds  String[] @db.ObjectId
  createdAt    DateTime @default(now())
}

model QuizConfig {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  questionsPerQuiz    Int      @default(7)
  secondsPerQuestion  Int      @default(10)
  completionCoins     Int      @default(20)
  coinsPerCorrect     Int      @default(10)
  updatedAt           DateTime @updatedAt
}

model QuizAttempt {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  date         String
  answers      Json
  correctCount Int
  coinsAwarded Int
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
}
